rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'maharshithefox@gmail.com';
    }

    // Helper to check if document belongs to user
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /user_profiles/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == userId) || isAdmin();
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == userId) || isAdmin();
    }

    match /payment_transactions/{transactionId} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || (request.auth != null && (resource.data.userId == request.auth.uid || resource.data.userEmail == request.auth.token.email));
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /autopay_mandates/{mandateId} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || (request.auth != null && (resource.data.userId == request.auth.uid || resource.data.userEmail == request.auth.token.email));
      allow update: if isAdmin() || (request.auth != null && (resource.data.userId == request.auth.uid || resource.data.userEmail == request.auth.token.email));
      allow delete: if isAdmin();
    }
    
    // Default fallback rules
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
